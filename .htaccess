RewriteEngine On
#RewriteCond %{SERVER_PORT} 80
#RewriteRule ^.*$ https://%{SERVER_NAME}%{REQUEST_URI} [R=301,L]
RewriteRule ^(.*)$ index.php [QSA]

ErrorDocument 404 https://%{SERVER_NAME}%{REQUEST_URI}/404

RewriteCond %{HTTP_HOST} ^www.%{SERVER_NAME}%{REQUEST_URI} [NC]
RewriteRule ^(.*)$ https://%{SERVER_NAME}%{REQUEST_URI}/$1 [R=301,L]